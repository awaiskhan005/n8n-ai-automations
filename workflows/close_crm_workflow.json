      "position": [680, 300],
      "parameters": {
        "url": "=https://api.close.com/api/v1/lead/{{ $('Extract Message Data').item.json.lead_id }}/",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "httpBasicAuth": {
          "user": "api_1IbhBHUrx0bbwcIpPMVm1T.4702HXKtvpeRWgMkQXv0wF",
          "password": ""
        },
        "options": {}
      }
    },
    {
      "id": "message-classification",
      "name": "Message Classification",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [900, 300],
      "parameters": {
        "rules": {
          "rules": [
            {
              "id": 1,
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $('Extract Message Data').item.json.message_text }}",
                    "rightValue": "who is this|what company|who are you|who do you work for",
                    "operator": {
                      "type": "regex",
                      "operation": "regex",
                      "rightType": "any"
                    }
                  }
                ],
                "combinator": "or"
              },
              "renameOutput": true,
              "outputKey": "identity_question"
            },
            {
              "id": 2,
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $('Extract Message Data').item.json.message_text }}",
                    "rightValue": "what do you want|how can i help|what's up|what's this about|what do you need",
                    "operator": {
                      "type": "regex",
                      "operation": "regex",
                      "rightType": "any"
                    }
                  }
                ],
                "combinator": "or"
              },
              "renameOutput": true,
              "outputKey": "purpose_question"
            },
            {
              "id": 3,
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $('Extract Message Data').item.json.message_text }}",
                    "rightValue": "yes|yep|i own|maybe.*what.*want|how can i help",
                    "operator": {
                      "type": "regex",
                      "operation": "regex",
                      "rightType": "any"
                    }
                  }
                ],
                "combinator": "or"
              },
              "renameOutput": true,
              "outputKey": "confirmation_response"
            },
            {
              "id": 4,
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $('Extract Message Data').item.json.message_text }}",
                    "rightValue": "sold.*property|no longer own|i sold it|it's sold|we sold",
                    "operator": {
                      "type": "regex",
                      "operation": "regex",
                      "rightType": "any"
                    }
                  }
                ],
                "combinator": "or"
              },
              "renameOutput": true,
              "outputKey": "property_sold"
            },
            {
              "id": 5,
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $('Extract Message Data').item.json.message_text }}",
                    "rightValue": "not interested.*selling|not selling|not for sale|just looking.*tenant|just leasing|never had.*for sale",
                    "operator": {
                      "type": "regex",
                      "operation": "regex",
                      "rightType": "any"
                    }
                  }
                ],
                "combinator": "or"
              },
              "renameOutput": true,
              "outputKey": "soft_no"
            },
            {
              "id": 6,
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $('Extract Message Data').item.json.message_text }}",
                    "rightValue": "selling.*ourselves|don't work with brokers|bring.*buyer.*pay|if you bring.*buyer|not looking to list|go sell it then|pay you.*buyer.*bring",
                    "operator": {
                      "type": "regex",
                      "operation": "regex",
                      "rightType": "any"
                    }
                  }
                ],
                "combinator": "or"
              },
              "renameOutput": true,
              "outputKey": "not_interested_broker"
            },
            {
              "id": 7,
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $('Extract Message Data').item.json.message_text }}",
                    "rightValue": "already working.*broker|property is listed|talk to.*agent|have a broker|already listed",
                    "operator": {
                      "type": "regex",
                      "operation": "regex",
                      "rightType": "any"
                    }
                  }
                ],
                "combinator": "or"
              },
              "renameOutput": true,
              "outputKey": "already_listed"
            },
            {
              "id": 8,
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $('Extract Message Data').item.json.message_text }}",
                    "rightValue": "under contract|in due diligence|in escrow|scheduled.*close|contract signed|closing soon",
                    "operator": {
                      "type": "regex",
                      "operation": "regex",
                      "rightType": "any"
                    }
                  }
                ],
                "combinator": "or"
              },
              "renameOutput": true,
              "outputKey": "under_contract"
            },
            {
              "id": 9,
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $('Extract Message Data').item.json.message_text }}",
                    "rightValue": "do you have.*buyer|you have someone.*wants.*buy|represent.*buyer|have.*buyer",
                    "operator": {
                      "type": "regex",
                      "operation": "regex",
                      "rightType": "any"
                    }
                  }
                ],
                "combinator": "or"
              },
              "renameOutput": true,
              "outputKey": "buyer_question"
            },
            {
              "id": 10,
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $('Extract Message Data').item.json.message_text }}",
                    "rightValue": "interest.*selling|yes please call|want to talk|call me",
                    "operator": {
                      "type": "regex",
                      "operation": "regex",
                      "rightType": "any"
                    }
                  }
                ],
                "combinator": "or"
              },
              "renameOutput": true,
              "outputKey": "wants_to_talk"
            }
          ]
        },
        "options": {}
      }
    },
