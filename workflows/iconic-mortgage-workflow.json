      "name": "Update Lead - Scheduled",
      "type": "n8n-nodes-base.salesforce",
      "typeVersion": 1,
      "position": [400, 800],
      "id": "update-scheduled",
      "credentials": {
        "salesforceOAuth2Api": {
          "id": "vvVDO8LQL3Oa72Wl",
          "name": "Salesforce account 2"
        }
      }
    },
    {
