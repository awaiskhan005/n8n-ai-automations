    {
      "id": "extract-message-data",
      "name": "Extract Message Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [460, 300],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "contact_phone",
              "name": "contact_phone",
              "value": "={{ $json.from }}",
              "type": "string"
            },
            {
              "id": "message_text",
              "name": "message_text",
              "value": "={{ $json.body.toLowerCase().trim() }}",
              "type": "string"
            },
            {
              "id": "lead_id",
              "name": "lead_id",
              "value": "={{ $json.lead_id || '' }}",
              "type": "string"
            },
            {
              "id": "current_workflow",
              "name": "current_workflow",
              "value": "={{ $json.current_workflow || '' }}",
              "type": "string"
            },
