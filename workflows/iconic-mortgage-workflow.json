        "to": "={{ $node['Check Schedule Need'].json.customerPhone }}",
        "message": "={{ 'Perfect! Your appointment with ' + $node['Check Schedule Need'].json.loanOfficerName + ' has been scheduled for ' + $node['Format Slots'].json.availableSlots[0].formatted + '. You\\'ll receive a reminder before the call. If you need to reschedule, please call ' + $node['Check Schedule Need'].json.loanOfficerPhone + '.' }}"
      },
      "name": "Confirm Appointment",
      "type": "n8n-nodes-base.twilio",
